@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var p = ViewBag.Data;
}

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moedas</title>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</head>

<main>
    <div class="container">
        <div class="d-flex align-items-center mb-4">
            <h1 class="h3 me-2">Moedas</h1>
            <span class="text-muted fs-6">> Editar</span>
        </div>

        <div class="text-end mb-3">
            <a href="/Currency" class="btn btn-secondary btn-sm" style="font-size:small;">Voltar</a>
        </div>

        <form action="/Currency/Update/@p.Id" method="post">
            <div class="card shadow-sm p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="Name" class="form-label">Nome:</label>
                        @await Component.InvokeAsync("TextInput", new { name = "Name", value = p.Name, maxlength = 100, placeholder = "Digite o nome da moeda" })
                    </div>
                    <div class="col-md-3">
                        <label for="Code" class="form-label">Código:</label>
                        @await Component.InvokeAsync("TextInput", new { name = "Code", value = p.Code, maxlength = 100, placeholder = "Digite o código da moeda" })
                    </div>
                    <div class="col-md-3">
                        <label for="Symbol" class="form-label">Símbolo:</label>
                        @await Component.InvokeAsync("TextInput", new { name = "Symbol", value = p.Symbol, maxlength = 100, placeholder = "Digite o símbolo da moeda" })
                    </div>
                </div>
            </div>
            <div class="text-center mt-4" style="font-size:small;">
                <button class="btn btn-primary btn-sm" type="submit">Salvar</button>
            </div>
        </form>
    </div>
</main>
