@model Finan.Web.Components.MessageModal.MessageModalModel

<div class="modal fade" id="@Model.Id" tabindex="-1" aria-hidden="true" style="font-size:small;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">

            <div class="modal-header bg-@Model.Type text-white">
                <h5 class="modal-title">@Model.Title</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <ul id="@Model.Id-body">
                    @foreach (var msg in Model.Messages)
                    {
                        <li>@msg</li>
                    }
                </ul>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Ok</button>
            </div>
        </div>
    </div>
</div>