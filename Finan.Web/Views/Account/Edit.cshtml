@model AccountViewModel
@*  
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860  
*@  
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var p = ViewBag.Data;
    var b = ViewBag.Banks;
}

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contas</title>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</head>

<main>
    <div class="container">
        <div class="d-flex align-items-center mb-4">
            <h1 class="h3 me-2">Contas</h1>
            <span class="text-muted fs-6">> Editar</span>
        </div>

        <div class="text-end mb-3" style="font-size:small;">
            <a href="/Account" class="btn btn-secondary btn-sm">Voltar</a>
        </div>

        <form asp-action="Update" asp-route-id="@p.Id" method="post">
            <div class="card shadow-sm p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="Name" class="form-label">Nome:</label>
                        @await Component.InvokeAsync("TextInput", new { name = "Name", value = p.Name, maxlength = 100, placeholder = "Digite o nome da conta." })
                    </div>

                    <div class="col-md-6">
                        <label for="BankId" class="form-label">Banco:</label>
                        @await Component.InvokeAsync("Dropdown", new { name = "BankId", items = b, selectedValue = p.BankId.ToString() })
                    </div>
                </div>

                <hr class="my-4" />

                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="Agency" class="form-label">Agência:</label>
                        @await Component.InvokeAsync("TextInput", new { name = "Agency", value = p.Agency, maxlength = 10, placeholder = "Digite a agência da contat" })
                    </div>

                    <div class="col-md-3">
                        <label for="Agency" class="form-label">Número:</label>
                        @await Component.InvokeAsync("TextInput", new { name = "Number", value = p.Number, maxlength = 15, placeholder = "Digite a número da conta" })
                    </div>

                    <div class="col-md-6">
                        <label for="CreditLimit" class="form-label">Crédito:</label>
                        @await Component.InvokeAsync("DecimalInput", new { name = "CreditLimit", value = p.CreditLimit })
                    </div>
                </div>
            </div>
            <div class="text-center mt-4">
                <button class="btn btn-primary" style="font-size:small;" type="submit">Salvar</button>
            </div>
        </form>
    </div>
</main>