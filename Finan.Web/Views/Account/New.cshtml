@model AccountViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var b = ViewBag.Banks;
}

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contas</title>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</head>

<main>
    <div class="container">
        <div class="d-flex align-items-center p-0 mb-4">
            <h1 class="h3 mb-0 me-2">Contas</h1>
            <span class="text-muted fs-6">> Novo</span>
        </div>

        <div class="text-end mb-3" style="font-size:small;">
            <a href="/Account" class="btn btn-secondary btn-sm">Voltar</a>
        </div>

        <form asp-action="Create" method="post">
            <div class="card shadow-sm p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="Name" class="form-label">Nome:</label>
                        @await Component.InvokeAsync("TextInput", new { model = ViewData.ModelExplorer.GetExplorerForProperty(nameof(Model.Name)), name = "Name", maxlength = 100, placeholder = "Digite o nome da conta." })
                    </div>
                    <div class="col-md-6">
                        <label for="BankId" class="form-label">Banco:</label>
                        @await Component.InvokeAsync("Dropdown", new { name = "BankId", items = b, selectedValue = "" })
                    </div>
                </div>

                <hr class="my-4">

                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="Agency" class="form-label">Agência:</label>
                        @await Component.InvokeAsync("TextInput", new { model = ViewData.ModelExplorer.GetExplorerForProperty(nameof(Model.Agency)), name = "Agency", maxlength = 10, placeholder = "Digite a agência da conta." })
                    </div>
                    <div class="col-md-3">
                        <label for="Number" class="form-label">Número:</label>
                        @await Component.InvokeAsync("TextInput", new { model = ViewData.ModelExplorer.GetExplorerForProperty(nameof(Model.Number)), name = "Number", maxlength = 15, placeholder = "Digite o número da conta." })
                    </div>
                    <div class="col-md-6">
                        <label for="CreditLimit" class="form-label">Crédito:</label>
                        @await Component.InvokeAsync("DecimalInput", new { model = ViewData.ModelExplorer.GetExplorerForProperty(nameof(Model.CreditLimit)), name = "CreditLimit" })
                    </div>
                </div>
            </div>
            <div class="text-center mt-4">
                <button class="btn btn-primary" style="font-size:small;" type="submit">Salvar</button>
            </div>
        </form>
    </div>
</main>