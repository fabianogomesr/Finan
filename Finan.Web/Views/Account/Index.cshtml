@using Finan.Web.Components.ConfirmModal
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var AccountList = ViewBag.Data;
}

@await Html.PartialAsync("Components/ConfirmModal/_ConfirmModal", new ConfirmModalModel())

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contas</title>
    <!-- Bootstrap CSS -->
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</head>

<main>
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3">Contas</h1>
        </div>

        <div class="text-end mb-3" style="margin-left:110px;">
            <a href="/Account/New" class="btn btn-success btn-sm" style="font-size:small">
                <i class="bi bi-plus-square-fill"></i> Nova Conta
            </a>
        </div>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                @TempData["Message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <table class="table table-hover table-bordered text-center align-middle mb-0" style="font-size:small">
            <thead>
                <tr>
                    <th class="visually-hidden">#</th>
                    <th>Nome</th>
                    <th>Banco</th>
                    <th>Agência</th>
                    <th>Número</th>
                    <th>Crédito</th>
                    <th>Saldo</th>
                    <th>Acões</th>
                </tr>
            </thead>
            <tbody>
                @if (AccountList.Items != null && AccountList.Items.Count > 0)
                {
                    @foreach (var p in AccountList.Items)
                    {
                        <tr>
                            <td class="visually-hidden">@p.Id</td>
                            <td>@p.BankName</td>
                            <td>@p.Name</td>
                            <td>@p.Agency</td>
                            <td>@p.Number</td>
                            <td>@p.CreditLimit.ToString("C")</td>
                            <td>@p.Balance.ToString("C")</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <button class="btn btn-sm btn-outline-secondary" onclick="statementView(@p.Id)">
                                        <i class="bi bi-receipt"></i> Extrato
                                    </button>
                                    <button class="btn btn-sm btn-outline-primary" onclick="editItem(@p.Id)">
                                        <i class="bi bi-pencil-square"></i> Editar
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" onclick="showConfirmModal('Deseja realmente excluir este item?', function() { deleteItem(@p.Id); })">
                                        <i class="bi bi-trash"></i> Excluir
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="12" class="text-center">Nenhum pagamento encontrado.</td>
                    </tr>
                }
            </tbody>
        </table>

        <nav class="mt-4" style="font-size:small">
            <ul class="pagination justify-content-center">
                @if (AccountList.Items != null && AccountList.Items.Count > 0)
                {
                    <li class="page-item @(AccountList.Page == 1 ? "disabled" : "")">
                        <a class="page-link" href="/Account/Page/@(AccountList.Page - 1)" aria-label="Previous">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>

                    @* Define o limite de páginas visíveis *@    
                    int maxVisiblePages = 5;
                    int startPage = Math.Max(1, AccountList.Page - (maxVisiblePages / 2));
                    int endPage = Math.Min(AccountList.TotalPages, startPage + maxVisiblePages - 1);

                    if (endPage - startPage + 1 < maxVisiblePages)
                    {
                        startPage = Math.Max(1, endPage - maxVisiblePages + 1);
                    }


                    @if (startPage > 1)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(AccountList.Page == i ? "active" : "")">
                            <a class="page-link" href="/Account/Page/@(i)">@i</a>
                        </li>
                    }

                    @if (endPage < AccountList.TotalPages)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }

                    <li class="page-item @(AccountList.Page == AccountList.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="/Account/Page/@(AccountList.Page + 1)" aria-label="Next">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled">
                        <a class="page-link" href="#" aria-label="Previous">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>
                    <li class="page-item disabled">
                        <a class="page-link" href="#" aria-label="Next">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</main>

<script>
    function deleteItem(id) {
        fetch(`/Account/Delete/${id}`, { method: 'POST' })
            .then(response => {
                if (response.ok) {
                    location.reload();
                }
            });
    }
    function editItem(id) {
        window.location.href = `/Account/Edit/${id}`;
    }
</script>