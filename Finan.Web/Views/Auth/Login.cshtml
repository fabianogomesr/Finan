@model LoginViewModel
@{

}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card">
                <div class="card-header text-center">
                    <h4 class="modal-title">Login</h4>
                </div>
                <div class="card-body">
                    @* Exibe mensagens de erro de validação *@
                    @if (ViewData.ModelState.Any())
                    {
                        <div class="alert alert-danger">
                            <ul class="mb-0">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            </ul>
                        </div>
                    }

                    @* Formulário de login *@
                    <form asp-action="Login" method="post" autocomplete="off">
                        <div class="form-group mb-3">
                            <label for="username" class="form-label fw-semibold">Usuário</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-person"></i></span>
                                <input asp-for="Username" id="username" name="username" class="form-control" placeholder="Digite seu usuário" />
                            </div>
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label for="password" class="form-label fw-semibold">Senha</label>
                            <a href="#" class="float-right text-muted">
                                <small>Esqueceu a senha?</small>
                            </a>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                                <input asp-for="Password" type="password" id="password" name="password" class="form-control" placeholder="Digite sua senha" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <label class="form-check-label">
                            <input type="checkbox" />
                            Remember me
                        </label>
                        <button type="submit" class="btn btn-primary w-100 mt-2 fw-bold">Entrar</button>
                    </form>
                    <div class="mt-4 text-center">
                        @if (TempData["Message"] != null)
                        {
                            <div class="alert alert-info alert-dismissible fade show" role="alert">
                                @TempData["Message"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                        <span>Não tem uma conta?</span>
                        <a href="/Auth/Register" class="btn btn-link p-0 align-baseline">Cadastre-se</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}