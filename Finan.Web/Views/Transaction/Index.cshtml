@using Finan.Web.Components.ConfirmModal
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var TransactionList = ViewBag.Data;
    var DateTypes = ViewBag.DateTypes;
    var DefaultDateType = ViewBag.DefaultDateType;
    var DefaultStartDate = ViewBag.DefaultStartDate;
    var DefaultEndDate = ViewBag.DefaultEndDate;
    var TotalEmAberto = ViewBag.TotalEmAberto;
    var TotalVencidos = ViewBag.TotalVencidos;
    var TotalPagos = ViewBag.TotalPagos;
}

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pagamentos</title>
    <!-- Bootstrap CSS -->
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8fafc;
        }

        .table-striped tbody tr:nth-of-type(odd) {
            background-color: #f8fafc;
        }
    </style>
</head>

@await Html.PartialAsync("Components/ConfirmModal/_ConfirmModal", new ConfirmModalModel())

<div class="container-fluid px-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3 mt-4 mb-0">Movimentações</h1>
        </div>
        <div class="col-auto d-flex align-items-center">
            <a href="/Transaction/New" class="btn btn-success btn-sm">
                <i class="bi bi-plus-square-fill"></i> Nova Movimentação
            </a>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body pb-2">
            <form method="get" class="row g-3 align-items-end" action="/Transaction/Index">
                <div class="col-md-3">
                    @await Component.InvokeAsync("Label", new { name = "DateType", Text = "Data de:" })
                    @await Component.InvokeAsync("Dropdown", new { name = "DateTypeId", items = DateTypes, selectedValue = DefaultDateType.ToString() })
                </div>
                <div class="col-md-2">
                    @await Component.InvokeAsync("Label", new { name = "startDate", Text = "De:" })
                    @await Component.InvokeAsync("DateInput", new { name = "startDate", value = DefaultStartDate })
                </div>
                <div class="col-md-2">
                    @await Component.InvokeAsync("Label", new { name = "endDate", Text = "Até:" })
                    @await Component.InvokeAsync("DateInput", new { name = "endDate", value = DefaultEndDate })
                </div>
                <div class="col-md-2">
                    <input type="checkbox" class="form-check-input" id="Canceled" name="Canceled" value="true" @(ViewBag.Canceled == true ? "checked" : "") />
                    @await Component.InvokeAsync("Label", new { name = "Canceled", Text = "Cancelado" })
                </div>
                <div class="col-auto d-flex align-items-end">
                    <button type="submit" class="btn btn-primary btn-sm w-100" style="height:33px">
                        <i class="bi bi-search"></i> Pesquisar
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert" style="font-size:small">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-bordered text-center align-middle mb-0" style="font-size:small;">
                    <thead>
                        <tr>
                            <th class="visually-hidden">#</th>
                            <th>Tipo</th>
                            <th>Centro</th>
                            <th>Grupo</th>
                            <th>Classificação</th>
                            <th>Moeda</th>
                            <th>Descrição</th>
                            <th>Valor</th>
                            <th>Total Pago</th>
                            <th>Vencimento</th>
                            <th>Situação</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (TransactionList.Items != null && TransactionList.Items.Count > 0)
                        {
                            @foreach (var p in TransactionList.Items)
                            {
                                <tr class="@(p.DueDate < DateTime.Now.Date && p.StatusName != "Pago" ? "table-danger" : "")">
                                    <td class="visually-hidden">@p.Id</td>
                                    <td>@p.TypeName</td>
                                    <td>@p.CostCenterName</td>
                                    <td>@p.GroupName</td>
                                    <td>@p.ClassificationName</td>
                                    <td>@p.CurrencyName</td>
                                    <td>@p.Description</td>
                                    <td>@p.Value.ToString("C")</td>
                                    <td>@p.TotalPaid.ToString("C")</td>
                                    <td>@p.DueDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="badge @(p.StatusName == "Pago" ? "bg-success" : "bg-warning text-dark")">
                                            @p.StatusName
                                        </span>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <button class="btn btn-sm btn-outline-primary" onclick="editItem(@p.Id)">
                                                <i class="bi bi-pencil-square"></i> Editar
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="12" class="text-center">Nenhuma despesa encontrada.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <nav class="mb-4">
        <ul class="pagination justify-content-center">
            @if (TransactionList.Items != null && TransactionList.Items.Count > 0)
            {
                <li class="page-item @(TransactionList.Page == 1 ? "disabled" : "")">
                    <a class="page-link" onclick="goToPage(@(TransactionList.Page - 1))" aria-label="Previous" style="cursor:pointer;">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>

 
                int maxVisiblePages = 5;
                int startPage = Math.Max(1, TransactionList.Page - (maxVisiblePages / 2));
                int endPage = Math.Min(TransactionList.TotalPages, startPage + maxVisiblePages - 1);

                if (endPage - startPage + 1 < maxVisiblePages)
                {
                    startPage = Math.Max(1, endPage - maxVisiblePages + 1);
                }
                

                @if (startPage > 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(TransactionList.Page == i ? "active" : "")">
                        <a class="page-link" onclick="goToPage(@(i))" style="cursor:pointer;">@i</a>
                    </li>
                }

                @if (endPage < TransactionList.TotalPages)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                <li class="page-item @(TransactionList.Page == TransactionList.TotalPages ? "disabled" : "")">
                    <a class="page-link" onclick="goToPage(@(TransactionList.Page + 1))" aria-label="Next" style="cursor:pointer;">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <a class="page-link" href="#" aria-label="Previous">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>
                <li class="page-item disabled">
                    <a class="page-link" href="#" aria-label="Next">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            }
        </ul>
    </nav>

    <div class="row mb-4">
        <div class="col-md-4 mb-2 mb-md-0">
            <div class="card text-center border-warning h-100">
                <div class="card-body">
                    <h6 class="card-title text-warning"><i class="bi bi-hourglass-split"></i> Em Aberto</h6>
                    <span class="display-6">@TotalEmAberto</span>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-2 mb-md-0">
            <div class="card text-center border-danger h-100">
                <div class="card-body">
                    <h6 class="card-title text-danger"><i class="bi bi-exclamation-triangle"></i> Vencidos</h6>
                    <span class="display-6">@TotalVencidos</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center border-success h-100">
                <div class="card-body">
                    <h6 class="card-title text-success"><i class="bi bi-check-circle"></i> Pagos</h6>
                    <span class="display-6">@TotalPagos</span>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    function editItem(id) {
        window.location.href = `/Transaction/Edit/${id}`;
    }

    function goToPage(page) {
        const dateType = document.querySelector('[name="DateTypeId"]')?.value || '';
        const startDate = document.querySelector('[name="startDate"]')?.value || '';
        const endDate = document.querySelector('[name="endDate"]')?.value || '';

        const params = new URLSearchParams({
            dateType: dateType,
            startDate: startDate,
            endDate: endDate,
            pageNumber: page
        });

        window.location.href = `/Transaction/?${params.toString()}`;
    }
</script>