@model TransactionViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var t = ViewBag.Types;
    var g = ViewBag.Groups;
    var c = ViewBag.Classifications;
    var o = ViewBag.CostCenters;
    var u = ViewBag.Currencies;
    var s = ViewBag.Status;
}

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/css/pages/transaction/edit.css" rel="stylesheet" />
</head>

<div id="transaction-new-root"
     data-status-paid-id="@ViewBag.StatusPaidId">
    <div class="container-fluid px-4">
        <div class="row mt-4 mb-3 align-items-center">
            <div class="col">
                <h1 class="h4 mb-0">Movimentações <small class="text-muted">> Novo</small></h1>
            </div>
            <div class="col-auto">
                <a href="/Transaction" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> Voltar
                </a>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <form action="/Transaction/Create" method="post" class="needs-validation" novalidate>
                    <div class="row g-3">
                        <div class="col-md-6">
                            @await Component.InvokeAsync("Label", new { name = "Description", Text = "Descrição:" })
                            @await Component.InvokeAsync("TextInput", new { name = "Description", maxlength = 100, placeholder = "Digite a descrição do recebimento" })
                        </div>
                        <div class="col-md-6">
                            @await Component.InvokeAsync("Label", new { name = "TypeId", Text = "Tipo:" })
                            @await Component.InvokeAsync("Dropdown", new { name = "TypeId", items = t, selectedValue = "" })
                        </div>
                        <div class="col-md-6">
                            @await Component.InvokeAsync("Label", new { name = "CostCenterId", Text = "Centro de Custo:" })
                            @await Component.InvokeAsync("Dropdown", new { name = "CostCenterId", items = o, selectedValue = "" })
                        </div>
                        <div class="col-md-6">
                            @await Component.InvokeAsync("Label", new { name = "GroupId", Text = "Grupo:" })
                            @await Component.InvokeAsync("Dropdown", new { name = "GroupId", items = g, selectedValue = "" })
                        </div>
                        <div class="col-md-6">
                            @await Component.InvokeAsync("Label", new { name = "ClassificationId", Text = "Classificação:" })
                            @await Component.InvokeAsync("Dropdown", new { name = "ClassificationId", items = c, selectedValue = "" })
                        </div>
                        <div class="col-md-6">
                            @await Component.InvokeAsync("Label", new { name = "CurrencyId", Text = "Moeda:" })
                            @await Component.InvokeAsync("Dropdown", new { name = "CurrencyId", items = u, selectedValue = "" })
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="row g-3">
                        <div class="col-md-4">
                            @await Component.InvokeAsync("Label", new { name = "Value", Text = "Valor:" })
                            @await Component.InvokeAsync("DecimalInput", new { model = ViewData.ModelExplorer.GetExplorerForProperty(nameof(Model.Value)), name = "Value" })
                        </div>
                        <div class="col-md-4">
                            @await Component.InvokeAsync("Label", new { name = "Discount", Text = "Desconto:" })
                            @await Component.InvokeAsync("DecimalInput", new { model = ViewData.ModelExplorer.GetExplorerForProperty(nameof(Model.Discount)), name = "Discount" })
                        </div>
                        <div class="col-md-4">
                            @await Component.InvokeAsync("Label", new { name = "LateFee", Text = "Juros:" })
                            @await Component.InvokeAsync("DecimalInput", new { model = ViewData.ModelExplorer.GetExplorerForProperty(nameof(Model.LateFee)), name = "LateFee" })
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="row g-3">
                        <div class="col-md-3">
                            @await Component.InvokeAsync("Label", new { name = "IssueDate", Text = "Data de Emissão:" })
                            @await Component.InvokeAsync("DateInput", new { name = "IssueDate" })
                        </div>
                        <div class="col-md-3">
                            @await Component.InvokeAsync("Label", new { name = "DueDate", Text = "Data de Vencimento:" })
                            @await Component.InvokeAsync("DateInput", new { name = "DueDate" })
                        </div>
                        <div class="col-md-3">
                            @await Component.InvokeAsync("Label", new { name = "CashFlowDate", Text = "Data de Fluxo:" })
                            @await Component.InvokeAsync("DateInput", new { name = "CashFlowDate" })
                        </div>
                        <div class="col-md-3">
                            @await Component.InvokeAsync("Label", new { name = "AccrualPeriodDate", Text = "Data de Competência:" })
                            @await Component.InvokeAsync("DateInput", new { name = "AccrualPeriodDate" })
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="row g-3">
                        <div class="col-md-6">
                            @await Component.InvokeAsync("Label", new { name = "Observation", Text = "Observação:" })
                            @await Component.InvokeAsync("TextInput", new { name = "Observation", maxlength = 100, placeholder = "Digite a observação do recebimento", required = false })
                        </div>
                        <div class="col-md-6">
                            @await Component.InvokeAsync("Label", new { name = "StatusId", Text = "Situação:" })
                            @await Component.InvokeAsync("Dropdown", new { name = "StatusId", items = s, selectedValue = "" })
                        </div>
                    </div>

                    <div id="paymentSection" style="display:none;">
                        <hr class="my-4" />

                        <div class="payment-subtitle">
                            <div class="accent" aria-hidden="true"></div>
                            <div>
                                <div class="title"><i class="bi bi-wallet2"></i> Dados de Pagamento</div>
                                <span class="subtitle">Preencha quando a movimentação for quitada. Campos opcionais para controle de pagamento.</span>
                            </div>
                        </div>

                        <div class="row g-3">

                            <div class="col-md-4">
                                @await Component.InvokeAsync("Label", new { name = "PaidValue", Text = "Valor Pago:" })
                                @await Component.InvokeAsync("DecimalInput", new { name = "PaidValue" })
                            </div>

                            <div class="col-md-4">
                                @await Component.InvokeAsync("Label", new { name = "PaidDate", Text = "Data de Pagamento:" })
                                @await Component.InvokeAsync("DateInput", new { name = "PaidDate" })
                            </div>

                            <div class="col-md-4">
                                @await Component.InvokeAsync("Label", new { name = "AccountId", Text = "Conta:" })
                                @await Component.InvokeAsync("Dropdown", new { name = "AccountId", items = ViewBag.Accounts, required = false })
                            </div>

                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <button class="btn btn-primary px-4" type="submit">
                            <i class="bi bi-save"></i> Salvar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<script type="module" src="~/js/dist/pages/transaction/new-transaction.js" asp-append-version="true"></script>